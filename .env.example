APP_NAME=go-simrs-app
APP_VERSION="1.0.0"

APP_ENV=development
APP_PORT=8080
APP_DEBUG=false

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=db_go_simrs

JWT_ISSUER=simrs-app
JWT_SECRET=jwt-secret
JWT_EXPIRATION=5 #minute
JWT_SECRET_REFRESH=jwt-secret-refresh
JWT_EXPIRATION_REFRESH=30 #day

LOG_FILE=.logs/app.log
LOG_MAX_SIZE=10
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=7
LOG_COMPRESS=true
LOG_LEVEL=debug

ALLOWED_ORIGINS=http://neurovi-simulation.test:3000,http://old-app.neurovi-simulation.test:3000,http://auth.neurovi-simulation.test:3000,http://localhost:3000
APP_DOMAIN=.neurovi-simulation.test